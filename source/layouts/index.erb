<% wrap_layout :layout do %>

    <%= partial "layouts/header" %>

    <main class="container">
        <% if blog_pages.empty? %>
            <h2>Coming soon!</h2>
        <% else %>
            <% blog_pages.each do |page| %>
                <hgroup>
                    <% link_to page.url do %>
                        <h3><%= page.data.title %></h3>
                    <% end %>

                    <h4>
                        <% if page.data.subtitle %>
                            <%= page.data.subtitle %>&nbsp;|&nbsp;
                        <% end %>
                        <%= format_date page.data.date %>
                    </h4>
                </hgroup>
            <% end %>
        <% end %>
    </main>
<% end %>
