<% wrap_layout :layout do %>

    <%= partial "layouts/header" %>

    <main class="container">
        <div class="grid">
            <section>
                <%= yield %>
            </section>

            <aside>
                <hgroup>
                    <h6>
                        <time datetime="<%= current_page.data.date %>">
                            <%= format_date current_page.data.date %>
                        </time>
                    </h6>
                    <p>Filed under: <%= current_page.data.category %></p>
                </hgroup>
            </aside>
        </div>
    </main>
<% end %>
